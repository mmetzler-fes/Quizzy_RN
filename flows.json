        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "<div class=\"container\">\n  <h1> Quizzy Eval</h1>\n  <h2> Es waren {{korrekt}} Felder korrekt ausgefüllt. </h2>\n  <h2> Das sind {{rating}} Prozent. </h2>\n  <form action=\"learn\" method=\"get\">\n    <input type=\"hidden\" name=\"username\" value=\"{{username}}\"> </input>\n    <input type=\"hidden\" name=\"quizname\" value=\"{{quizname}}\"> </input>\n    <input type=\"hidden\" name=\"date\" value=\"{{date}}\"> </input>\n   <button type=\"submit\"> Nochmal versuchen? </button>\n\n  </form>\n</div>",
