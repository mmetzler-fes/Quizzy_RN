        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "<div class=\"container\">\n  <h1> Quizzy </h1>\n  <form action=\"eval\" method=\"post\">\n  <div class=\"row\">\n    <div class=\"column-md-6\"> \n      <table class=\"table table-hover\">\n        <thead>\n          <tr>\n             <th scope=\"col\">Ordne die Begriffe der Nummer der Beschreibung zu</th>\n            <th scope=\"col\">Begriffe</th>\n            <th scope=\"col\">Nummer</th>\n            <th scope=\"col\">Beschreibung</th>\n          </tr>\n        </thead>\n        <tbody>\n          {{#payload}}\n          <tr class=\"table-active\">\n            <input name=\"{{rowId}}\" type=\"hidden\" value=\"{{rowid}}\">\n            <td><input name=\"{{randomRowId}}\" autocomplete=\"off\" type=\"number\" placeholder=\"  \" ></input></td>\n            <td>{{query}}</td>\n            <td name=\"origRowid\">{{origRowId}}</td>          \n            <td>{{randomAnswer}}</td>\n           \n          </tr>\n          {{/payload}}\n        </tbody>\n      </table>\n\n    </div>  \n  </div>  \n  <input type=\"hidden\" name=\"username\" value=\"{{username}}\"> </input>\n  <input type=\"hidden\" name=\"quizname\" value=\"{{quizname}}\"> </input>\n  <input type=\"hidden\" name=\"date\" value=\"{{date}}\"> </input>\n  <input type=\"hidden\" name=\"totalnumber\" value=\"{{totalnumber}}\"> </input>\n\n  <button type=\"submit\">Absenden</button>  \n  </form>\n</div>\n",
        "output": "str",
