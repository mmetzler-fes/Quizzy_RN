    {
        "id": "ed3fd2b77b1835b7",
        "type": "function",
        "z": "012e717f75994bd8",
        "name": "Eval",
        "func": "var korrekt=0;\nvar i=0;\nfor (let row in msg.payload) {\n   var number=parseInt(msg.payload[row]);\n   if (number == parseInt(row)) korrekt++;\n   i++;\n}\nmsg.payload.korrekt=korrekt;\nvar totalnumber = parseFloat(msg.payload.totalnumber);\nmsg.payload.rating = Math.round(korrekt * 100 / totalnumber);\nmsg.korrekt=korrekt;\nmsg.rating = Math.round(korrekt * 100 / totalnumber);\nmsg.username = msg.payload.username;\nmsg.quizname = msg.payload.quizname;\nmsg.date = new Date();\nreturn msg;",
        "outputs": 1,
