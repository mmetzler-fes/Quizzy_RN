    {
        "id": "349161e8a6086d4c",
        "type": "function",
        "z": "012e717f75994bd8",
        "name": "INSERT quizzy",
        "func": "var liste = [[\"<title>HTML5-Grundgerüst</title>\", \"Titelzeile im Browserfenster\"],\n[\"<body>\", \"Umschließt den Inhalt, der im Browserfenster angezeigt wird\"],\n['<html lang=\"de\">', \"Umschließt den kompletten Inhalt und es wird im Inhalt als Sprache Deutsch verwendet\"],\n[\"<header> ... </header>\", \"Kopfzeile der HTML-Seite\"],\n[\"<nav> ... </nav>\", \"Bereich zur Steuerung (Navigation) der HTML-Seite\"],\n[\"<main>..</main>\", \"Hauptteil der HTML-Seite\"],\n[\"<h1> … </h1>\", \" Hauptüberschrift - wichtig, sollte einmal auf jeder einzelnen Seite kommen\"],\n[\"<p> … </p>\", \" Absatz - nach dem Absatz wird automatisch Platz gehalten\"],\n[\"<strong> … </strong>\", \"wichtiger Bereich, Schrift wird fett angezeigt\"],\n['<a href=\"URL\">BESCHREIBUNG</a>', \"Hyperlink für interne und externe Links\"],\n['<link rel=\"stylesheet\" href=\"main.css\" type=\"text/css\">', \"Referenz auf eine CSS-Datei\"],\n[\"<ul> … </ul>\", \"Ungeordnete Auflistung\"],\n[\"<li>AUFZÄHLUNGSPUNKT</li>\", \"Jeder einzelne Punkt bei einer Aufzählung muss von diesem HTML-Befehl umschlossen werden.\"]];\nvar quizname=msg.quizname;\nvar message1 = \"INSERT INTO quizzy VALUES(\";\nfor (var i=0; i<liste.length; i++) {\n   var message2 = \"(select rowid from quizzylist where quizname like '\" + quizname + \"'),\" ;\n   message2 += \"'\"+liste[i][0] + \"'\"+ \", '\"  + liste[i][1] + \"'\";\n   if (i< liste.length-1) {\n       message2 += \"), (\";\n   }\n   message1 += message2;\n}\nmsg.payload=message1+\");\";\nmsg.topic=msg.payload;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 560,
        "wires": [
            [
                "af21fc227a455624"
            ]
        ]
    },
