    {
        "id": "4e5e71f2d6f802ff",
        "type": "function",
        "z": "012e717f75994bd8",
        "name": "Payload erweitern",
        "func": "function shuffle(myArray) {\n    var arrayLength = myArray.length;\n    if (arrayLength == 0) return false; // false wenn das Array leer ist\n    for (var i = 0; i < arrayLength; i++) {\n        //zufaellige Nummer aus dem Array auswaehlen\n        var j = Math.floor(Math.random() * (arrayLength - 1));\n        //aktuelle Arraynummer mit dem zufaellig generierten austauschen (swap)\n        var tempi = myArray[i];\n        var tempj = myArray[j];\n        myArray[i] = tempj;\n        myArray[j] = tempi;\n    }\n    return myArray;\n}\nvar myMessage = msg;\n\n//myMessage.topic=\"quizzy\";\n//myMessage.payload=msg.payload;\nvar sortedArray=new Array(msg.payload.length);\nfor (var i = 0; i < msg.payload.length; i++) {\n    sortedArray[i]=i+1;\n    myMessage.payload[i].origRowId = i+1;\n}\nvar myRandomArray=shuffle(sortedArray);\n\nfor (var i=0; i < msg.payload.length; i++) {\n   \n   myMessage.payload[i].rowid = msg.payload[i].rowid;\n   myMessage.payload[i].randomRowId = myRandomArray[i];\n   myMessage.payload[myRandomArray[i]-1].randomAnswer=msg.payload[i].answer;\n}\nmyMessage.username = msg.req.query.username;\nmyMessage.quizname = msg.req.query.quizname;\nmyMessage.date = new Date();\nmyMessage.totalnumber = msg.payload.length;\nreturn myMessage;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
